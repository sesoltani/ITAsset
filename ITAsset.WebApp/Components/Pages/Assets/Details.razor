@page "/Assets/Details/{AssetId:int}"
@using ITAsset.Data.Services
@using ITAsset.Domain.Common
@using ITAsset.Domain.Entities
@using ITAsset.Domain.Interfaces
@using ITAsset.WebApp.Helpers
@using ITAsset.WebApp.ViewModels


@inject IAssetService AssetService
@inject IPcComponentService PcComponentService
@inject IPcComponentHistoryService HistoryService
@inject IAssetAssignmentHistoryService AssignmentHistoryService
@inject IAssetAssignmentService AssetAssignmentService
@inject IEmployeeService EmployeeService


<h3>جزئیات تجهیز</h3>

@if (asset == null)
{
    <p>در حال بارگذاری...</p>
}
else
{
    <div class="mb-3">
        <strong>IT Code:</strong> @asset.ITCode
        <br />
        <strong>کد اموال:</strong> @asset.AssetCode
        <br />
        <strong>مدل:</strong> @asset.Model?.Brand?.Name - @asset.Model?.Name
        <br />
        <strong>وضعیت:</strong> @asset.Status
        <br />
        <strong>مکان:</strong> @asset.Location?.Name
    </div>

    @if (activeAssignment == null)
    {
        <button class="btn btn-primary mb-3" @onclick="OpenAssignModal">
            📤 تحویل تجهیز
        </button>
    }
    else
    {
        <div class="alert alert-warning mb-3">
            <strong>⛔ این تجهیز در حال حاضر تحویل شده است</strong><br />
            👤 کارمند: @activeAssignment.EmployeeName<br />
            🕒 از تاریخ: @activeAssignment.AssignedDate.ToString("yyyy/MM/dd")<br />
            🧾 وضعیت هنگام تحویل: @activeAssignment.ConditionOnAssign
        </div>

        <button class="btn btn-outline-success"
                @onclick="() => OpenReturnModal(activeAssignment.AssignmentId)">
            📥 عودت تجهیز
        </button>
    }

    @if (asset != null && assignmentTimeline.Any(t => t.Action == "تحویل تجهیز"))
    {
        <button class="btn btn-success" @onclick="async () => await ReturnAsset()">

            📥 بازگرداندن تجهیز
        </button>
    }


    @if (!assignmentTimeline.Any())
    {
        <div class="alert alert-secondary">
            هنوز سابقه تحویل برای این تجهیز ثبت نشده است.
        </div>
    }
    else
    {
        <h5 class="mt-4">تاریخچه تحویل تجهیز</h5>

        <ul class="timeline">
            @foreach (var item in assignmentTimeline)
            {
                <li>
                    <span class="timeline-date">
                        @item.Date.ToString("yyyy/MM/dd HH:mm")
                    </span>

                    <div class="timeline-content">
                        <strong>@item.Action</strong>
                        <br />
                        <span>کارمند: @item.EmployeeName</span><br />
                        <span>وضعیت: @item.Condition</span><br />
                        <span class="text-muted">توسط: @item.ChangedBy</span>

                        @if (!string.IsNullOrEmpty(item.Note))
                        {
                            <div class="text-muted small mt-1">
                                📝 @item.Note
                            </div>
                        }
                    </div>
                </li>
            }
        </ul>
    }

    <h5>قطعات کیس</h5>
    <button class="btn btn-success mb-2" @onclick="OpenInstallModal">
        ➕ نصب قطعه
    </button>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-info">@message</div>
    }

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>نوع قطعه</th>
                <th>IT Code</th>
                <th>برند</th>
                <th>مدل</th>
                <th>Serial</th>
                <th>عملیات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var comp in components)
            {
                <tr>
                    <td>@comp.ComponentType</td>
                    <td>@comp.ITCode</td>
                    <td>@comp.Brand</td>
                    <td>@comp.Model</td>
                    <td>@comp.SerialNumber</td>
                    <td>
                        <button class="btn btn-danger btn-sm"
                                @onclick="() => OpenRemoveModal(comp.Id, comp.ComponentType!)">
                            ❌ حذف
                        </button>
                        <button class="btn btn-warning btn-sm"
                                @onclick="() => OpenReplaceModal(comp.Id)">
                            🔄 تعویض
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<h5>تاریخچه قطعات</h5>
@if (!historyList.Any())
{
    <div class="alert alert-secondary">
        هنوز تغییری برای قطعات این تجهیز ثبت نشده است.
    </div>
}
else
{

    <div class="timeline">
        @foreach (var h in historyList)
        {
            <div class="timeline-item">
                <div class="timeline-dot @ChangeTypeUiHelper.GetBadgeClass(h.ChangeType)"></div>

                <div class="timeline-content">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="badge @ChangeTypeUiHelper.GetBadgeClass(h.ChangeType)">
                            @h.ChangeTypeTitle
                        </span>

                        <small class="text-muted">
                            @h.ChangeDate.ToString("yyyy/MM/dd HH:mm")
                        </small>
                    </div>

                    <div>
                        <strong>@h.ComponentType</strong>
                        @if (!string.IsNullOrEmpty(h.ITCode))
                        {
                            <span class="text-muted">(IT: @h.ITCode)</span>
                        }
                    </div>

                    <div class="text-muted small">
                        توسط @h.ChangedBy
                    </div>

                    <button class="btn btn-sm btn-outline-primary mt-2"
                            @onclick="() => OpenHistoryModal(h)">
                        مشاهده جزئیات
                    </button>
                </div>
            </div>
        }
    </div>
}

<!-- مودال history -->
<div class="modal fade @(isModalOpen ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">جزئیات تغییر قطعه</h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                @if (selectedHistory != null)
                {
                    <dl class="row">
                        <dt class="col-sm-3">نوع قطعه</dt>
                        <dd class="col-sm-9">@selectedHistory.ComponentType</dd>

                        <dt class="col-sm-3">IT Code</dt>
                        <dd class="col-sm-9">@selectedHistory.ITCode</dd>

                        <dt class="col-sm-3">نوع تغییر</dt>
                        <dd class="col-sm-9">@selectedHistory.ChangeType</dd>

                        <dt class="col-sm-3">کاربر</dt>
                        <dd class="col-sm-9">@selectedHistory.ChangedBy</dd>

                        <dt class="col-sm-3">تاریخ</dt>
                        <dd class="col-sm-9">@selectedHistory.ChangeDate.ToString("yyyy/MM/dd HH:mm")</dd>
                    </dl>

                    @if (!string.IsNullOrEmpty(selectedHistory.OldInfo))
                    {
                        <h6>اطلاعات قبلی</h6>
                        <pre class="bg-light p-2">@selectedHistory.OldInfo</pre>
                    }

                    @if (!string.IsNullOrEmpty(selectedHistory.NewInfo))
                    {
                        <h6>اطلاعات جدید</h6>
                        <pre class="bg-light p-2">@selectedHistory.NewInfo</pre>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">بستن</button>
            </div>
        </div>
    </div>
</div>



<!-- مودال نصب قطعه -->
@if (showInstallModal)
{
    <div class="modal fade show d-block">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">نصب قطعه جدید</h5>
                    <button class="btn-close" @onclick="CloseInstallModal"></button>
                </div>

                <EditForm Model="componentVm" OnValidSubmit="InstallComponent">
                    <DataAnnotationsValidator />
                    <div class="modal-body row">

                        <div class="col-md-6 mb-3">
                            <label class="form-label">نوع قطعه</label>
                            <InputText class="form-control"
                                       @bind-Value="componentVm.ComponentType" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">کد IT</label>
                            <InputText class="form-control"
                                       @bind-Value="componentVm.ITCode" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">برند</label>
                            <InputText class="form-control"
                                       @bind-Value="componentVm.Brand" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">مدل</label>
                            <InputText class="form-control"
                                       @bind-Value="componentVm.Model" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Serial</label>
                            <InputText class="form-control"
                                       @bind-Value="componentVm.SerialNumber" />
                        </div>

                        <div class="col-12 mb-3">
                            <label class="form-label">مشخصات (JSON / متن آزاد)</label>
                            <InputTextArea class="form-control"
                                           @bind-Value="componentVm.Specifications" />
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-secondary"
                                type="button"
                                @onclick="CloseInstallModal">
                            انصراف
                        </button>
                        <button class="btn btn-primary" type="submit">ثبت</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

<!-- مودال حذف قطعه -->
@if (showRemoveModal)
{
    <div class="modal fade show d-block">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">تایید حذف قطعه</h5>
                    <button class="btn-close" @onclick="CloseRemoveModal"></button>
                </div>
                <div class="modal-body">
                    آیا مطمئن هستید که قطعه <strong>@removeComponentName</strong> حذف شود؟
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseRemoveModal">انصراف</button>
                    <button class="btn btn-danger" @onclick="RemoveComponent">حذف</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

<!-- مودال تعویض قطعه -->
@if (showReplaceModal)
{
    <div class="modal fade show d-block">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">تعویض قطعه</h5>
                    <button class="btn-close" @onclick="CloseReplaceModal"></button>
                </div>

                <EditForm Model="replaceVm" OnValidSubmit="ReplaceComponent">
                    <DataAnnotationsValidator />
                    <div class="modal-body row">

                        <div class="col-md-6 mb-3">
                            <label class="form-label">نوع قطعه</label>
                            <InputText class="form-control" @bind-Value="replaceVm.ComponentType" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">کد IT</label>
                            <InputText class="form-control" @bind-Value="replaceVm.ITCode" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">برند</label>
                            <InputText class="form-control" @bind-Value="replaceVm.Brand" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">مدل</label>
                            <InputText class="form-control" @bind-Value="replaceVm.Model" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Serial</label>
                            <InputText class="form-control" @bind-Value="replaceVm.SerialNumber" />
                        </div>

                        <div class="col-12 mb-3">
                            <label class="form-label">مشخصات (JSON / متن آزاد)</label>
                            <InputTextArea class="form-control" @bind-Value="replaceVm.Specifications" />
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-secondary" type="button" @onclick="CloseReplaceModal">انصراف</button>
                        <button class="btn btn-primary" type="submit">تعویض</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

<!-- مودال تحویل تجهیز -->
@if (showAssignModal)
{
    <div class="modal fade show d-block">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">تحویل تجهیز به کارمند</h5>
                    <button class="btn-close" @onclick="CloseAssignModal"></button>
                </div>
                <EditForm Model="assignVm" OnValidSubmit="AssignAsset">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">کارمند</label>
                            <InputSelect class="form-control" @bind-Value="assignVm.EmployeeId">
                                <option value="">انتخاب کارمند</option>
                                @foreach (var emp in employees)
                                {
                                    <option value="@emp.Id">@emp.FirstName @emp.LastName</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">وضعیت تجهیز هنگام تحویل</label>
                            <InputSelect class="form-control" @bind-Value="assignVm.ConditionOnAssign">
                                @foreach (AssetCondition c in Enum.GetValues(typeof(AssetCondition)))
                                {
                                    <option value="@c">@c</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">تاریخ بازگشت احتمالی</label>
                            <InputDate class="form-control" @bind-Value="assignVm.ExpectedReturnDate" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">یادداشت</label>
                            <InputTextArea class="form-control" @bind-Value="assignVm.Note" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" type="button" @onclick="CloseAssignModal">انصراف</button>
                        <button class="btn btn-primary" type="submit">ثبت تحویل</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

<!-- مودال مرجوع کردن تجهیز -->
@if (showReturnModal)
{
    <div class="modal fade show d-block">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">عودت تجهیز</h5>
                    <button class="btn-close" @onclick="CloseReturnModal"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">وضعیت تجهیز هنگام عودت</label>
                        <InputSelect class="form-control" @bind-Value="returnCondition">
                            @foreach (AssetCondition c in Enum.GetValues(typeof(AssetCondition)))
                            {
                                <option value="@c">@c</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseReturnModal">
                        انصراف
                    </button>
                    <button class="btn btn-success" @onclick="ReturnAsset">
                        ثبت عودت
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}




@code {
    [Parameter] public int AssetId { get; set; }

    private Asset? asset;
    private List<PcComponent> components = new();
    private string? message;

    // نصب قطعه
    private bool showInstallModal = false;
    private PcComponentCreateVm componentVm = new();

    // حذف قطعه
    private bool showRemoveModal = false;
    private int removeComponentId;
    private string removeComponentName = string.Empty;

    //تعویض قطعه
    private bool showReplaceModal = false;
    private int replaceOldComponentId;
    private PcComponentCreateVm replaceVm = new();

    //history
    private List<PcComponentHistoryVm> historyList = new();
    private PcComponentHistoryVm? selectedHistory;
    private bool isModalOpen = false;

    private List<AssignmentTimelineVm> assignmentTimeline = new();
    private bool showAssignModal = false;
    private AssetAssignVm assignVm = new();
    private List<Employee> employees = new();

    private bool showReturnModal = false;
    private int returnAssignmentId;
    private AssetCondition returnCondition;
    private AssetReturnVm returnVm = new();

    private ActiveAssignmentVm? activeAssignment;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsset();
        await LoadHistory(AssetId);
        await LoadAssignmentTimeline();
        await LoadEmployees();
        await LoadActiveAssignment();
    }

    private async Task LoadEmployees()
    {
        employees = await EmployeeService.GetAllAsync();
    }

    private async Task LoadAsset()
    {
        var result = await AssetService.GetByIdAsync(AssetId);
        if (result.IsSuccess)
        {
            asset = result.Data;
            // components = asset?.PcComponents.ToList() ?? new List<PcComponent>();
            var compResult = await PcComponentService.GetByAssetIdAsync(AssetId);
            components = compResult.Data ?? new List<PcComponent>();
        }
        else
        {
            message = result.Message;
        }
    }

    // --- نصب قطعه ---
    void OpenInstallModal()
    {
        componentVm = new PcComponentCreateVm
        {
            ParentAssetId = asset!.Id
        };
        showInstallModal = true;
    }

    void CloseInstallModal() => showInstallModal = false;

    private async Task InstallComponent()
    {
        var entity = new PcComponent
        {
            ParentAssetId = componentVm.ParentAssetId,
            ComponentType = componentVm.ComponentType,
            ITCode = componentVm.ITCode,
            Brand = componentVm.Brand,
            Model = componentVm.Model,
            SerialNumber = componentVm.SerialNumber,
            Specifications = componentVm.Specifications
        };

        var result = await PcComponentService.AddAsync(entity, userId: 1);

        if (result.IsSuccess)
        {
            components.Add(result.Data!);
            await LoadHistory(AssetId);
            showInstallModal = false;
            message = "قطعه با موفقیت نصب شد";
        }
        else
        {
            message = result.Message;
        }
    }

    // --- حذف قطعه ---
    void OpenRemoveModal(int id, string name)
    {
        removeComponentId = id;
        removeComponentName = name;
        showRemoveModal = true;
    }

    void CloseRemoveModal() => showRemoveModal = false;

    private async Task RemoveComponent()
    {
        var result = await PcComponentService.RemoveAsync(removeComponentId, userId: 1);

        if (result.IsSuccess)
        {
            var compToRemove = components.FirstOrDefault(c => c.Id == removeComponentId);
            if (compToRemove != null)
                components.Remove(compToRemove);

            await LoadHistory(AssetId);
            showRemoveModal = false;
            message = "قطعه با موفقیت حذف شد";
        }
        else
        {
            message = result.Message;
        }
    }

    // --- تعویض قطعه ---
    void OpenReplaceModal(int componentId)
    {
        replaceOldComponentId = componentId;
        var oldComp = components.FirstOrDefault(c => c.Id == componentId);
        if (oldComp != null)
        {
            replaceVm = new PcComponentCreateVm
            {
                ParentAssetId = asset!.Id,
                ComponentType = oldComp.ComponentType!,
                ITCode = oldComp.ITCode!,
                Brand = oldComp.Brand,
                Model = oldComp.Model,
                SerialNumber = oldComp.SerialNumber,
                Specifications = oldComp.Specifications
            };
            showReplaceModal = true;
        }
    }

    void CloseReplaceModal() => showReplaceModal = false;

    private async Task ReplaceComponent()
    {
        var newComponent = new PcComponent
        {
            ParentAssetId = replaceVm.ParentAssetId,
            ComponentType = replaceVm.ComponentType,
            ITCode = replaceVm.ITCode,
            Brand = replaceVm.Brand,
            Model = replaceVm.Model,
            SerialNumber = replaceVm.SerialNumber,
            Specifications = replaceVm.Specifications
        };

        var result = await PcComponentService.ReplaceAsync(replaceOldComponentId, newComponent, userId: 1);

        if (result.IsSuccess)
        {
            // جایگزینی در لیست
            var index = components.FindIndex(c => c.Id == replaceOldComponentId);
            if (index >= 0)
                components[index] = result.Data!;

            await LoadHistory(AssetId);
            showReplaceModal = false;
            message = "قطعه با موفقیت تعویض شد";
        }
        else
        {
            message = result.Message;
        }
    }

    //history
    private async Task LoadHistory(int assetId)
    {
        var result = await HistoryService.GetByAssetIdAsync(assetId);
        if (result.IsSuccess && result.Data != null)
        {
            historyList = result.Data.Select(h => new PcComponentHistoryVm
            {
                ComponentType = h.PcComponent?.ComponentType ?? "-",
                ITCode = h.PcComponent?.ITCode,
                OldInfo = h.OldComponentInfo,
                NewInfo = h.NewComponentInfo,
                ChangeType = h.ChangeType,
                ChangedBy = h.ChangedByUser?.UserName ?? "-",
                ChangeDate = h.ChangeDate
            }).ToList();
        }
    }

    private void OpenHistoryModal(PcComponentHistoryVm h)
    {
        selectedHistory = h;
        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
        selectedHistory = null;
    }

    private async Task LoadAssignmentTimeline()
    {
        var result = await AssignmentHistoryService.GetByAssetIdAsync(AssetId);

        if (result.IsSuccess && result.Data != null)
        {
            assignmentTimeline = result.Data.Select(h => new AssignmentTimelineVm
            {
                Action = h.Action == AssignmentAction.Assign ? "تحویل تجهیز" : "عودت تجهیز",
                EmployeeName = h.Employee != null
                    ? $"{h.Employee.FirstName} {h.Employee.LastName}"
                    : "-",
                Condition = h.Condition?.ToString() ?? "-",
                ChangedBy = h.ChangedByUser?.UserName ?? "-",
                Date = h.ChangeDate,
                Note = h.Note
            }).ToList();
        }
    }

    void OpenAssignModal()
    {
        assignVm = new AssetAssignVm
        {
            AssetId = asset!.Id
        };
        showAssignModal = true;
    }

    void CloseAssignModal() => showAssignModal = false;

    private async Task AssignAsset()
    {
        // فرض می‌کنیم شناسه کاربری که عملیات را انجام می‌دهد 1 است
        int currentUserId = 1;

        await AssetAssignmentService.AssignAsync(
            assetId: assignVm.AssetId,
            employeeId: assignVm.EmployeeId,
            assignedByUserId: currentUserId,
            conditionOnAssign: assignVm.ConditionOnAssign,
            expectedReturnDate: assignVm.ExpectedReturnDate
        );

        await LoadAssignmentTimeline(); // بروزرسانی Timeline
        showAssignModal = false;
        message = "تجهیز با موفقیت تحویل شد";
    }

    void OpenReturnModal(int assignmentId)
    {
        returnAssignmentId = assignmentId;
        returnCondition = AssetCondition.Good; // مقدار پیش‌فرض
        showReturnModal = true;
    }


    void CloseReturnModal() => showReturnModal = false;

    private async Task ReturnAsset()
    {
        await AssetAssignmentService.ReturnAsync(
            returnAssignmentId,
            performedByUserId: 1,
            returnCondition
        );

        showReturnModal = false;

        await LoadAssignmentTimeline();
        await LoadActiveAssignment();

        message = "تجهیز با موفقیت عودت داده شد";
    }


    private async Task LoadActiveAssignment()
    {
        var assignment = await AssetAssignmentService.GetActiveAssignmentAsync(AssetId);

        if (assignment != null)
        {
            activeAssignment = new ActiveAssignmentVm
            {
                AssignmentId = assignment.Id,
                EmployeeName = $"{assignment.Employee?.FirstName} {assignment.Employee?.LastName}",
                AssignedDate = assignment.AssignedDate,
                ConditionOnAssign = assignment.ConditionOnAssign
            };
        }
        else
        {
            activeAssignment = null;
        }
    }

}